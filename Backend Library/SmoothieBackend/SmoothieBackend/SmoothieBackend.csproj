<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <PropertyGroup>
        <BlenderAddonDir>F:\dev0\prjk\Smoothie\Blender Addon\lib</BlenderAddonDir>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="WolvenKit.Common" Version="8.19.0" />
      <PackageReference Include="WolvenKit.Core" Version="8.19.0" />
      <PackageReference Include="WolvenKit.Modkit" Version="8.19.0" />
      <PackageReference Include="WolvenKit.RED4" Version="8.19.0" />
    </ItemGroup>
    
    <Target Name="CopyToBlender" AfterTargets="Build">
        <ItemGroup>
            <FilesToCopy Include="$(TargetDir)$(AssemblyName).*" />
        </ItemGroup>

        <Copy
                SourceFiles="@(FilesToCopy)"
                DestinationFolder="$(BlenderAddonDir)"
                SkipUnchangedFiles="true" />
    </Target>
    
</Project>
